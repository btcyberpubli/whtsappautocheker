    {
      "name": "PUT - Resolver Alerta",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Primero obtener una alerta para saber su ID",
              "pm.sendRequest('http://localhost:3010/api/whatsapp-alerts', function (err, response) {",
              "    if (!err && response.json().alerts.length > 0) {",
              "        var alertId = response.json().alerts[0].id;",
              "        pm.environment.set('alertId', alertId);",
              "        console.log('AlertId obtenido:', alertId);",
              "    }",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code es 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Alerta marcada como resolved', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.eql(true);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"resolved\"\n}"
        },
        "url": {
          "raw": "http://localhost:3010/api/whatsapp-alert/:alertId",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3010",
          "path": [
            "api",
            "whatsapp-alert",
            ":alertId"
          ],
          "variable": [
            {
              "key": "alertId",
              "value": "alert-1234567890-abc123",
              "description": "Reemplaza con un ID real de alerta"
            }
          ]
        },
        "description": "Marca una alerta como resuelta. IMPORTANTE: Reemplaza :alertId con un ID real de la lista GET"
      },
      "response": []
    },
