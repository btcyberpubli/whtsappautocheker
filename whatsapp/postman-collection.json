{
  "info": {
    "_postman_id": "whatsapp-alerts-api",
    "name": "WhatsApp Alerts API - Superbot",
    "description": "Colección para probar los endpoints de alertas de WhatsApp",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST - Recibir Alerta",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response tiene success = true', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.eql(true);",
              "});",
              "",
              "pm.test('Response tiene alertId', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('alertId');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"whatsapp-downline\",\n  \"contactName\": \"Juan Pérez\",\n  \"chatId\": \"chat-{{$timestamp}}\",\n  \"lastMessage\": \"Última actualización fue hace 2 horas\",\n  \"detectedAt\": \"{{$timestamp}}\",\n  \"severity\": \"high\",\n  \"source\": \"whatsapp-extension\"\n}"
          }
        },
        "url": {
          "raw": "http://localhost:3010/api/whatsapp-alert",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3010",
          "path": [
            "api",
            "whatsapp-alert"
          ]
        },
        "description": "Envía una alerta de caída de WhatsApp al servidor"
      },
      "response": []
    },
